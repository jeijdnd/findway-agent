{
  "name": "findway-agent",
  "version": "2.0.0",
  "description": "FindWay Agent V2 - 建筑导视标识设计AI助手",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node scripts/dev-launcher.js",
    "dev:inner": "concurrently \"node scripts/start-vite.js\" \"wait-on http://localhost:5173 && node scripts/start-electron.js\"",
    "build": "npm run frontend-build && electron-builder",
    "frontend-build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "electron-start": "node scripts/start-electron.js"
  },
  "build": {
    "appId": "com.findway.agent",
    "productName": "FindWay Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "frontend/dist/**/*",
      "backend/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "frontend/public/favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "electron-store": "^8.2.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  }
}
