{
  "name": "create_project",
  "version": "1.0.0",
  "description": "创建项目并添加到项目仪表盘中，需要 name 和 path 参数",
  "icon": "plus-square",
  "category": "项目管理",
  "entry": "main.py",
  "parameters": {
    "name": {
      "type": "string",
      "description": "项目名称"
    },
    "path": {
      "type": "string",
      "description": "项目目录路径"
    },
    "project_type": {
      "type": "string",
      "description": "项目类型（学校/办公/住宅等，可选）"
    }
  }
}
